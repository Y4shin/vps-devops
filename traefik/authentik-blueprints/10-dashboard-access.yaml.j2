version: 1
metadata:
  name: traefik-dashboard-access
  labels:
    blueprints.goauthentik.io/instantiate: "true"
entries:
  - model: authentik_core.group
    id: traefik_dashboard_access_group
    state: present
    identifiers:
      name: traefik-dashboard-access
    attrs:
      name: traefik-dashboard-access

  - model: authentik_policies_expression.expressionpolicy
    id: traefik_dashboard_access_policy
    state: present
    identifiers:
      name: traefik dashboard requires traefik-dashboard-access
    attrs:
      name: traefik dashboard requires traefik-dashboard-access
      expression: |
        user = getattr(request, "user", None)
        return bool(
            user
            and user.is_authenticated
            and user.ak_groups.filter(name="traefik-dashboard-access").exists()
        )

  - model: authentik_providers_proxy.proxyprovider
    id: traefik_dashboard_proxy_provider
    state: present
    identifiers:
      name: traefik dashboard
    attrs:
      name: traefik dashboard
      external_host: https://traefik.{{ secrets.domain }}
      mode: forward_single
      authentication_flow: !Find [authentik_flows.flow, [slug, default-authentication-flow]]
      authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
      invalidation_flow: !Find [authentik_flows.flow, [slug, default-invalidation-flow]]

  - model: authentik_core.application
    id: traefik_dashboard_application
    state: present
    identifiers:
      slug: traefik-dashboard
    attrs:
      name: Traefik Dashboard
      slug: traefik-dashboard
      provider: !KeyOf traefik_dashboard_proxy_provider
      meta_launch_url: https://traefik.{{ secrets.domain }}
      meta_description: Access to the Traefik dashboard
      meta_publisher: vps-devops

  - model: authentik_policies.policybinding
    state: present
    identifiers:
      target: !KeyOf traefik_dashboard_application
      policy: !KeyOf traefik_dashboard_access_policy
      order: 0

  - model: authentik_outposts.outpost
    state: present
    identifiers:
      name: authentik Embedded Outpost
    attrs:
      providers:
        - !KeyOf traefik_dashboard_proxy_provider
